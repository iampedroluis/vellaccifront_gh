# URL de tu sitio WordPress (sin barra final)
VITE_WORDPRESS_URL=https://tu-sitio-wordpress.com

# URL del proxy backend (en produccion, tu servidor proxy)
VITE_API_BASE_URL=http://localhost:4000/api

# Claves WooCommerce - SOLO para el servidor proxy, NUNCA en el frontend
# WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
